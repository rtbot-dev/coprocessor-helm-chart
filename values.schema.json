{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "commonLabels": {
      "$ref": "#/definitions/stringMap"
    },
    "commonAnnotations": {
      "$ref": "#/definitions/stringMap"
    },
    "images": {
      "type": "object",
      "properties": {
        "rtbotRedis": {
          "$ref": "#/definitions/image"
        },
        "sqlRunner": {
          "$ref": "#/definitions/image"
        },
        "connect": {
          "$ref": "#/definitions/image"
        }
      }
    },
    "serviceAccount": {
      "type": "object",
      "properties": {
        "create": {
          "type": "boolean"
        },
        "name": {
          "type": "string"
        },
        "labels": {
          "$ref": "#/definitions/stringMap"
        },
        "annotations": {
          "$ref": "#/definitions/stringMap"
        }
      }
    },
    "statefulset": {
      "type": "object",
      "properties": {
        "replicas": {
          "type": "integer",
          "minimum": 1
        },
        "terminationGracePeriodSeconds": {
          "type": "integer",
          "minimum": 0
        },
        "labels": {
          "$ref": "#/definitions/stringMap"
        },
        "annotations": {
          "$ref": "#/definitions/stringMap"
        }
      }
    },
    "headlessService": {
      "type": "object",
      "properties": {
        "labels": {
          "$ref": "#/definitions/stringMap"
        },
        "annotations": {
          "$ref": "#/definitions/stringMap"
        }
      }
    },
    "service": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string"
        },
        "port": {
          "type": "integer",
          "minimum": 1
        },
        "nodePort": {
          "type": ["integer", "null"],
          "minimum": 1
        },
        "labels": {
          "$ref": "#/definitions/stringMap"
        },
        "annotations": {
          "$ref": "#/definitions/stringMap"
        }
      }
    },
    "thingsboard": {
      "type": "object",
      "properties": {
        "baseUrl": {
          "type": "string"
        },
        "existingSecret": {
          "type": "string"
        },
        "existingSecretKey": {
          "type": "string"
        }
      }
    },
    "sql": {
      "type": "object",
      "properties": {
        "mountPath": {
          "type": "string"
        },
        "existingConfigMap": {
          "type": "string"
        },
        "files": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "bootstrapJob": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "backoffLimit": {
              "type": "integer",
              "minimum": 0
            },
            "hook": {
              "type": "boolean"
            },
            "annotations": {
              "$ref": "#/definitions/stringMap"
            },
            "labels": {
              "$ref": "#/definitions/stringMap"
            }
          }
        }
      }
    },
    "connect": {
      "type": "object",
      "properties": {
        "mountPath": {
          "type": "string"
        },
        "port": {
          "type": "integer",
          "minimum": 1
        },
        "existingConfigMap": {
          "type": "string"
        },
        "extraEnv": {
          "type": "array"
        },
        "extraEnvFrom": {
          "type": "array"
        },
        "resources": {
          "type": "object"
        },
        "ingress": {
          "type": "object",
          "properties": {
            "path": {
              "type": "string"
            },
            "allowedVerbs": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "minItems": 1
            },
            "timeout": {
              "type": "string"
            },
            "deviceIdHeader": {
              "type": "string"
            },
            "timestampHeader": {
              "type": "string"
            },
            "successStatus": {
              "type": "string"
            },
            "errorStatus": {
              "type": "string"
            },
            "maxStreamLength": {
              "type": "integer",
              "minimum": 1
            },
            "maxInFlight": {
              "type": "integer",
              "minimum": 1
            }
          }
        },
        "egress": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "stream": {
              "type": "string"
            },
            "streams": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "consumerGroup": {
              "type": "string"
            },
            "clientId": {
              "type": "string"
            },
            "startFromOldest": {
              "type": "boolean"
            },
            "commitPeriod": {
              "type": "string"
            },
            "retries": {
              "type": "integer",
              "minimum": 0
            },
            "retryPeriod": {
              "type": "string"
            },
            "timeout": {
              "type": "string"
            }
          }
        }
      }
    },
    "rtbotRedis": {
      "type": "object",
      "properties": {
        "port": {
          "type": "integer",
          "minimum": 1
        },
        "args": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "extraEnvFrom": {
          "type": "array"
        },
        "resources": {
          "type": "object"
        }
      }
    },
    "sqlRunner": {
      "type": "object",
      "properties": {
        "extraEnv": {
          "type": "array"
        },
        "extraEnvFrom": {
          "type": "array"
        },
        "resources": {
          "type": "object"
        }
      }
    },
    "persistence": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "accessModes": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "size": {
          "type": "string"
        },
        "storageClassName": {
          "type": "string"
        },
        "labels": {
          "$ref": "#/definitions/stringMap"
        },
        "annotations": {
          "$ref": "#/definitions/stringMap"
        }
      }
    },
    "secret": {
      "type": "object",
      "properties": {
        "create": {
          "type": "boolean"
        },
        "labels": {
          "$ref": "#/definitions/stringMap"
        },
        "annotations": {
          "$ref": "#/definitions/stringMap"
        },
        "stringData": {
          "$ref": "#/definitions/stringMap"
        }
      }
    },
    "podLabels": {
      "$ref": "#/definitions/stringMap"
    },
    "podAnnotations": {
      "$ref": "#/definitions/stringMap"
    },
    "nodeSelector": {
      "$ref": "#/definitions/stringMap"
    },
    "tolerations": {
      "type": "array"
    },
    "affinity": {
      "type": "object"
    }
  },
  "definitions": {
    "stringMap": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "image": {
      "type": "object",
      "properties": {
        "repository": {
          "type": "string"
        },
        "tag": {
          "type": ["string", "number"]
        },
        "pullPolicy": {
          "type": "string"
        }
      },
      "required": [
        "repository",
        "tag",
        "pullPolicy"
      ]
    }
  }
}
